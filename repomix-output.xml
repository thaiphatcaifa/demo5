<file path="src/styles/globals.css">
@import "tailwindcss";

/* ===== BRAND BE ABLE VN — Forest Green (Brand Guideline v1.0) ===== */
@theme {
  --color-forest-green: #2B6830;   /* Chủ đạo */
  --color-forest-dark: #1E5225;    /* Section/banner/footer, highlight đậm */
  --color-forest-medium: #3D8B47;  /* Accent: hover, badge, divider */
  --color-forest-light: #E8F4EC;   /* Nền card sáng */
  --color-off-white: #F2F8F4;      /* Nền trang */
  --color-ink: #2C2C2C;            /* Text chính */
  --color-cream: #FBF7EC;          /* Chữ ấm trên nền tối (immersive) */

  --font-sans: "Be Vietnam Pro", sans-serif;
  --font-serif: "Be Vietnam Pro", sans-serif;
}

/* ===== IMMERSIVE — "tràn & sống động" ===== */
html { scroll-behavior: smooth; }
body { background: #F2F8F4; color: #2C2C2C; }

/* Hiện dần khi cuộn tới (dùng với component Reveal) */
@keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: none; } }
.reveal { opacity: 0; }
.reveal.is-visible { animation: fadeUp 0.75s cubic-bezier(0.22, 0.61, 0.36, 1) forwards; }

/* Ken Burns: ảnh hero phóng chậm cho sống động */
@keyframes kenburns { from { transform: scale(1.02); } to { transform: scale(1.14); } }
.hero-kenburns { animation: kenburns 20s ease-out forwards; }

/* Mũi tên cuộn nhấp nhô */
@keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(8px); } }
.animate-bob { animation: bob 1.8s ease-in-out infinite; }

/* Card nâng khi hover */
.lift { transition: transform 0.35s cubic-bezier(0.22,0.61,0.36,1), box-shadow 0.35s ease; }
.lift:hover { transform: translateY(-6px); box-shadow: 0 18px 40px -12px rgba(30,82,37,0.35); }

/* Tôn trọng người tắt hiệu ứng */
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  .reveal, .reveal.is-visible, .hero-kenburns, .animate-bob { animation: none !important; opacity: 1 !important; transform: none !important; }
}
</file>

